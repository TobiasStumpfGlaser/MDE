<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primaryDark</item>
        <item name="colorAccent">@color/accentRed</item>
    </style>

    <style name="Theme.MDE.Light" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/mde_light_primary</item>
        <item name="colorPrimaryDark">@color/mde_light_primary</item>
        <item name="colorAccent">@color/mde_light_primary</item>
        <item name="android:windowBackground">@color/mde_light_background</item>
        <item name="android:textColorPrimary">@color/mde_light_text</item>
        <item name="android:textColorSecondary">@color/mde_light_text</item>
        <item name="tableRowOddColor">@color/tableRowOddLight</item>
        <item name="tableRowEvenColor">@color/tableRowEvenLight</item>
    </style>

    <style name="Theme.MDE.Dark" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/mde_dark_primary</item>
        <item name="colorPrimaryDark">@color/mde_dark_primary</item>

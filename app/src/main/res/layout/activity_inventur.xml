<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?android:attr/windowBackground">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        android:minHeight="?attr/actionBarSize"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/ic_launcher_foreground"
                android:scaleType="fitCenter"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <!-- Abstand -->
            <View
                android:layout_width="8dp"
                android:layout_height="match_parent" />

            <TextView
                android:id="@+id/txtHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BW MDE"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="25sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- ScrollContainer -->
    <ScrollView
        android:id="@+id/scrollContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Artikel -->
                <AutoCompleteTextView
                    android:id="@+id/etBarcode"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="?attr/editTextBackground"
                    android:completionThreshold="1"
                    android:hint="Artikel suchen"
                    android:inputType="textVisiblePassword"
                    android:textAlignment="viewStart"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp" />

                <!-- Abstand -->
                <View
                    android:layout_width="8dp"
                    android:layout_height="match_parent" />

                <!-- Reload Button -->
                <ImageButton
                    android:id="@+id/btnReloadArtikel"
                    android:layout_width="70dp"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Neu laden"
                    android:layout_marginBottom="3dp"
                    android:src="@drawable/baseline_refresh_24" />
            </LinearLayout>

            <!-- Projekt -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp">

                <!-- Menge -->
                <EditText
                    android:id="@+id/edtMenge"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_weight="1"
                    android:background="?attr/editTextBackground"
                    android:hint="Menge"
                    android:inputType="numberDecimal"
                    android:textAlignment="viewStart" />

                <View
                    android:layout_width="16dp"
                    android:layout_height="match_parent" />

                <!-- Clear -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnClear"
                    android:layout_width="match_parent"
                    android:layout_weight="1"
                    android:layout_height="70dp"
                    android:text="Zurücksetzen" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCount"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:text="Zählung Senden" />

            <!-- Artikel Info (BaseActivity ID: tvArtikelInfo) -->
            <TextView
                android:id="@+id/tvArtikelInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="20sp" />

            <!-- Scan Button (BaseActivity ID: btnScan) -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnScan"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:visibility="gone"
                android:text="Scan" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
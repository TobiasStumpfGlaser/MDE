<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/grayBackground"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Titel -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grundeinstellungen"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColorLink="@color/white"
            android:textColorHint="@color/white"
            android:textColor="@color/white"
            android:paddingBottom="24dp" />

        <!-- Server IP -->
        <TextView
            android:layout_width="match_parent"
            android:text="Server IP"
            android:textColorLink="@color/white"
            android:textColorHint="@color/white"
            android:textColor="@color/white"
            android:layout_height="20dp" />
        <EditText
            android:id="@+id/etServerIp"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Server IP"
            android:inputType="text"
            android:background="@android:drawable/edit_text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <!-- Server Port -->
        <TextView
            android:layout_width="match_parent"
            android:text="Server Port"
            android:textColorLink="@color/white"
            android:textColorHint="@color/white"
            android:textColor="@color/white"
            android:layout_height="20dp" />
        <EditText
            android:id="@+id/etServerPort"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Server Port"
            android:inputType="number"
            android:background="@android:drawable/edit_text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <!-- Timeout -->
        <TextView
            android:layout_width="match_parent"
            android:text="Timeout Kommunikation (Sekunden)"
            android:textColorLink="@color/white"
            android:textColorHint="@color/white"
            android:textColor="@color/white"
            android:layout_height="20dp" />
        <EditText
            android:id="@+id/etTimeout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Timeout Kommunikation (Sekunden)"
            android:inputType="number"
            android:background="@android:drawable/edit_text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <!-- Logout Zeit -->
        <TextView
            android:layout_width="match_parent"
            android:text="Timeout Inaktivität (Sekunden)"
            android:textColorLink="@color/white"
            android:textColorHint="@color/white"
            android:textColor="@color/white"
            android:layout_height="20dp" />
        <EditText
            android:id="@+id/etLogoutTime"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Timeout Inaktivität (Sekunden)"
            android:inputType="number"
            android:background="@android:drawable/edit_text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <!-- Werksnummer -->
        <TextView
            android:layout_width="match_parent"
            android:text="Werksnummer"
            android:textColorLink="@color/white"
            android:textColorHint="@color/white"
            android:textColor="@color/white"
            android:layout_height="20dp" />
        <EditText
            android:id="@+id/etWerkNummer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Werksnummer"
            android:inputType="text"
            android:background="@android:drawable/edit_text"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

        <!-- Speichern -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@android:drawable/edit_text"
            android:text="Speichern" />

    </LinearLayout>
</ScrollView>

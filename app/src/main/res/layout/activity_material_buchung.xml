<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/grayBackground">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:background="@color/cardview_dark_background"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:title="BW MDE App"
        app:titleTextColor="@color/white"/>

    <!-- ScrollContainer -->
    <ScrollView
        android:id="@+id/scrollContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Artikel -->
            <AutoCompleteTextView
                android:id="@+id/txtArtikel"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@android:drawable/edit_text"
                android:hint="Artikel suchen"
                android:textAlignment="center"
                android:completionThreshold="1"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"/>

            <!-- Projekt -->
            <AutoCompleteTextView
                android:id="@+id/txtProjekt"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@android:drawable/edit_text"
                android:hint="Projekt suchen"
                android:textAlignment="center"
                android:completionThreshold="1"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"/>

            <!-- Menge -->
            <EditText
                android:id="@+id/edtMenge"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@android:drawable/edit_text"
                android:hint="Menge (+ / -)"
                android:inputType="text"
                android:textAlignment="center"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="24dp"/>

            <!-- Scan -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnScanArtikel"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@android:drawable/edit_text"
                android:text="Scan"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"/>

            <!-- Buchen -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnBuchen"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@android:drawable/edit_text"
                android:text="Buchen"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"/>

            <!-- Clear -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnClear"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@android:drawable/edit_text"
                android:text="Zurücksetzen"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"/>

            <!-- Reload -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnReloadData"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@android:drawable/edit_text"
                android:text="Daten Aktualisieren"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"/>

            <!-- Status -->
            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textAlignment="center"
                android:textSize="18sp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
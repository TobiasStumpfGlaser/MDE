<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/grayBackground">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:background="@color/cardview_dark_background"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:title="BW MDE App"
        app:titleTextColor="@color/white"/>

    <!-- ScrollContainer -->
    <ScrollView
        android:id="@+id/scrollContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Status -->
            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textAlignment="center"
                android:textSize="10sp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"/>

            <!-- Artikel (BaseActivity ID: etBarcode) -->
            <AutoCompleteTextView
                android:id="@+id/etBarcode"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:inputType="textVisiblePassword"
                android:background="@android:drawable/edit_text"
                android:hint="Artikel suchen"
                android:textAlignment="viewStart"
                android:completionThreshold="1"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"/>

            <!-- Projekt -->
            <AutoCompleteTextView
                android:id="@+id/txtProjekt"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@android:drawable/edit_text"
                android:hint="Projekt suchen"
                android:inputType="textVisiblePassword"
                android:textAlignment="viewStart"
                android:completionThreshold="1"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp">
            <!-- Menge -->
            <EditText
                android:id="@+id/edtMenge"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:background="@android:drawable/edit_text"
                android:hint="Menge"
                android:inputType="number"
                android:textAlignment="viewStart"/>

            <View
                android:layout_width="16dp"
                android:layout_height="match_parent"/>

            <!-- Clear -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnClear"
                android:layout_width="match_parent"
                android:layout_weight="1"
                android:layout_height="70dp"
                android:background="@android:drawable/edit_text"
                android:text="Zurücksetzen"/>
        </LinearLayout>

            <!-- Einlagern / Auslagern Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <!-- Einlagern -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnEinlagern"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_weight="1"
                    android:backgroundTint="@android:color/holo_green_light"
                    android:text="Zubuchung"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"/>

                <View
                    android:layout_width="16dp"
                    android:layout_height="match_parent"/>

                <!-- Auslagern -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnAuslagern"
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_weight="1"
                    android:backgroundTint="@android:color/holo_red_light"
                    android:text="Entnahme"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Artikel Info (BaseActivity ID: tvArtikelInfo) -->
            <TextView
                android:id="@+id/tvArtikelInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="20sp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"/>

            <!-- Reload Artikel Button (BaseActivity ID: btnReloadArtikel) -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnReloadArtikel"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@android:drawable/edit_text"
                android:text="Neu laden"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"/>

            <!-- Scan Button (BaseActivity ID: btnScan) -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnScan"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@android:drawable/edit_text"
                android:text="Scan"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
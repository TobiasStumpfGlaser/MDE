<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/grayBackground">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:background="@color/cardview_dark_background"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:title="BW MDE App"
        app:titleTextColor="@color/white"/>

    <!-- Scrollbarer Hauptbereich -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/mainContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Info Scan -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnInfoScan"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@android:drawable/edit_text"
                android:text="Info Scan"
                android:visibility="gone"
                android:textSize="20sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="10dp" />

            <!-- Material Buchung -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnMaterialBook"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@android:drawable/edit_text"
                android:text="Material Buchung"
                android:textSize="20sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="10dp" />

            <!-- Picklist -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPicklist"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@android:drawable/edit_text"
                android:text="Picklist"
                android:textSize="20sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="10dp" />

            <!-- Picklist -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnDroplist"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@android:drawable/edit_text"
                android:text="Droplist"
                android:textSize="20sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="10dp" />

            <!-- Picklist -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnInventur"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@android:drawable/edit_text"
                android:text="Ist-Zähluing"
                android:textSize="20sp" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>